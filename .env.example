# Optional: TeraBox `ndus` cookie so /api/terabox-media can stream lectures on your site.
# Log in at https://www.terabox.app → DevTools → Application → Cookies → copy `ndus` value.
TERABOX_NDUS=

# Optional: override TeraBox metadata resolver (defaults to tera-core.vercel.app)
# VITE_TERABOX_RESOLVER_API=https://tera-core.vercel.app/api
